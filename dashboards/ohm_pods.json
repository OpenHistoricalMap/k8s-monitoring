{
  "uid": "ee6soeyovgf7ke",
  "title": "OHM pods",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "ohm"
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "custom",
        "multi": false,
        "includeAll": false,
        "query": "All : .*, k3s : ^$, aws-eks : aws-eks",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "k3s",
            "value": "^$"
          },
          {
            "selected": false,
            "text": "aws-eks",
            "value": "aws-eks"
          }
        ]
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PROMETHEUS_SOURCE_ID"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1,
        "definition": "label_values(kube_pod_status_phase{cluster=~\"$cluster\"}, namespace)",
        "query": "label_values(kube_pod_status_phase{cluster=~\"$cluster\"}, namespace)",
        "current": {
          "selected": true,
          "text": [
            "default"
          ],
          "value": [
            "default"
          ]
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pods running",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_SOURCE_ID"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_SOURCE_ID"
          },
          "expr": "sum(kube_pod_status_phase{phase=\"Running\", cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods pending / failed / unknown",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_SOURCE_ID"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
