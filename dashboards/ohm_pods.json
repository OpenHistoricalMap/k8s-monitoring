            "type": "prometheus",
            "uid": "PROMETHEUS_SOURCE_ID"
          },
          "expr": "sum((kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\", cluster=~\"$cluster\", namespace=~\"$namespace\"} == 1) and on (cluster, namespace, pod, container) (increase(kube_pod_container_status_restarts_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[24h]) > 0)) or vector(0)",
          "instant": true
        }
      ]
