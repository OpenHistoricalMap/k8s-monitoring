# Copy to .env and fill in. .env is gitignored — never commit it.

# --- k3s central stack (deploy_k3s.sh) ---
GRAFANA_ADMINPASSWORD=
# Where alert emails go (comma-separated for several recipients)
ALERT_EMAIL_TO=
# AWS SES SMTP credentials (SES console -> SMTP settings -> Create SMTP credentials)
SMTP_USERNAME=
SMTP_PASSWORD=

# --- EKS agent (deploy_eks.sh) ---
# https://prometheus.ohmstaging.org/api/v1/write (staging)
# https://prometheus.openhistoricalmap.org/api/v1/write (production)
REMOTE_WRITE_URL=
# Cloudflare Access service token (Zero Trust -> Access -> Service credentials)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
